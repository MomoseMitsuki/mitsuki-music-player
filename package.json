{
	"name": "mitsuki-music-player",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"lint:prettier": "prettier --write \"**/*.{js,ts,mjs,cjs,json,tsx,css,less,scss,vue,html,md}\"",
		"lint:eslint": "eslint . --fix --cache",
		"lint:spellcheck": "cspell lint \"packages/**/*.{js,ts,mjs,cjs,json,css,less,scss,vue,html,md}\"",
		"commit": "git-cz",
		"prepare": "husky",
		"dev": "turbo run dev",
		"build": "turbo run build",
		"lint": "run-s lint:*",
		"dev:web": "pnpm --filter @mitsuki-music-player/web dev",
		"build:web": "pnpm --filter @mitsuki-music-player/web build"
	},
	"config": {
		"commitizen": {
			"path": "node_modules/cz-git"
		}
	},
	"keywords": [],
	"author": "mitsuki",
	"license": "ISC",
	"packageManager": "pnpm@11.1.0",
	"engines": {
		"node": ">=24.12.0",
		"npm": ">=11.6.0",
		"pnpm": ">=10.15.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.3.1",
		"@commitlint/config-conventional": "^20.3.1",
		"@cspell/dict-lorem-ipsum": "^4.0.5",
		"@eslint/js": "^9.39.2",
		"@types/node": "^25.0.9",
		"commitizen": "^4.3.1",
		"cspell": "^9.6.0",
		"cz-git": "^1.12.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-vue": "^10.7.0",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.0",
		"turbo": "^2.9.14",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.0",
		"vue-eslint-parser": "^10.2.0"
	}
}
